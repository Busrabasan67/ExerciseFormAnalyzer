<resources>
    <!-- AppCompatActivity için Theme.AppCompat tabanlı bir tema zorunlu. -->
    <!-- Compose tüm UI'ı render eder; bu tema sadece Activity için şart. -->
    <style name="Theme.ExerciseFormAnalyzer" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="android:windowTranslucentStatus">true</item>
        <item name="android:windowTranslucentNavigation">true</item>
    </style>

    <!-- Android 12+ Splash Screen Theme -->
    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#00B4D8</item>
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher</item>
        <item name="postSplashScreenTheme">@style/Theme.ExerciseFormAnalyzer</item>
    </style>
</resources>
